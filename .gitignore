# Terraform local state
*.tfstate
*.tfstate.*

# Terraform plan output files
*.tfplan
plan.out

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Terraform lock and override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config files
.terraformrc
terraform.rc

# Terraform working directory
.terraform/

# Keep dependency lock file versioned
!.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# IDE/OS noise
.DS_Store
.vscode/
.idea/
